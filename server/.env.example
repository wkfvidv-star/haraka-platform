# Server Configuration
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
# Connect to Supabase or local Postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/student_dashboard?schema=public"

# Security (JWT)
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="super_secret_jwt_key_change_me"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="super_secret_refresh_key_change_me"
JWT_REFRESH_EXPIRES_IN="7d"

# AI Services
OPENAI_API_KEY="sk-..."
HF_API_KEY="hf_..."

# Logging
LOG_LEVEL="info"

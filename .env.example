# Demo API Configuration (Local Mocking)
# Real API keys are no longer required.
OPENAI_API_KEY=not_needed_for_demo
HF_API_KEY=not_needed_for_demo

# Server Configuration
PORT=3001
NODE_ENV=development

# Security Settings
JWT_SECRET=demo-secret-key-123
JWT_REFRESH_SECRET=demo-refresh-secret-456
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
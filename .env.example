# AI & Media Processing Configuration
# Real keys for Llama 2, Whisper, and YOLOv8 worker
OPENAI_API_KEY=your_openai_key_here
LLAMA_API_URL=http://localhost:11434/api/generate  # Ollama/Llama 2
WHISPER_API_URL=http://localhost:5000/transcribe
YOLO_WORKER_URL=http://localhost:8000/analyze
HF_API_KEY=your_huggingface_key_here

# Infrastructure (Supabase & pgvector)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Server Configuration
PORT=3001
NODE_ENV=development

# Security Settings
JWT_SECRET=demo-secret-key-123
JWT_REFRESH_SECRET=demo-refresh-secret-456
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
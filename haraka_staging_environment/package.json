{
  "name": "haraka-staging-environment",
  "version": "2.0.0-staging",
  "description": "بيئة التجريب لمنصة حركة - تحليل الأداء الحركي للطلاب",
  "type": "module",
  "scripts": {
    "dev:staging": "vite --mode staging --port 5174 --host",
    "build:staging": "tsc && vite build --mode staging",
    "preview:staging": "vite preview --mode staging --port 4174",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test:staging": "vitest --mode staging",
    "db:setup:staging": "node scripts/setup-staging-db.js",
    "db:migrate:staging": "node scripts/migrate-staging.js",
    "db:seed:staging": "node scripts/seed-staging-data.js",
    "staging:start": "concurrently \"npm run dev:staging\" \"npm run api:staging\"",
    "api:staging": "node server/staging-server.js",
    "deploy:staging": "npm run build:staging && npm run deploy:staging:only",
    "rollback:production": "echo 'Rolling back to production version...' && cd ../shadcn-ui && npm run dev"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@supabase/supabase-js": "^2.38.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "tailwind-merge": "^2.0.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@metagptx/vite-plugin-source-locator": "^0.0.6",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "staging": {
    "database": "haraka_staging",
    "environment": "staging",
    "features": [
      "video_upload",
      "ai_analysis",
      "real_time_notifications"
    ],
    "rollback_command": "npm run rollback:production"
  }
}

# ──────────────────────────────
# 🚀 Haraka Platform - .gitignore
# ──────────────────────────────

# === Logs & Debug Files ===
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# === Dependencies & Builds ===
node_modules/
dist/
dist-ssr/
build/
coverage/
.cache/
out/
.next/
.vite/
.temp/

# === Local Environment Files ===
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# Prevent leaking Supabase keys or API tokens
supabase/.env
supabase/config.json

# === Editor & System Files ===
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# === OS & Miscellaneous ===
*.local
*.tmp
*.bak
*.log.*
*.orig

# === Frontend build outputs (Vite/React) ===
*.tsbuildinfo
*.eslintcache

# === Optional: Backup or temporary files ===
backup/
temp/
tmp/
.vercel

# =================================
# منصة حركة - متغيرات البيئة النموذجية
# Haraka Platform - Environment Variables Template
# =================================

# معلومات التطبيق
# Application Information
NEXT_PUBLIC_APP_NAME="منصة حركة"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NODE_ENV="development"

# =================================
# Supabase Configuration
# =================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
SUPABASE_JWT_SECRET="your-jwt-secret-here"

# =================================
# Database Configuration
# =================================
DATABASE_URL="postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres"
DATABASE_POOL_SIZE="10"
DATABASE_SSL="true"

# =================================
# Authentication & Security
# =================================
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-256-bits-long"
JWT_EXPIRES_IN="24h"
BCRYPT_ROUNDS="12"

# =================================
# Server Configuration
# =================================
PORT="3000"
HOST="0.0.0.0"
CORS_ORIGINS="http://localhost:3000,https://haraka.edu.sa"

# =================================
# File Upload & Storage
# =================================
NEXT_PUBLIC_MAX_FILE_SIZE="104857600"
NEXT_PUBLIC_ALLOWED_FILE_TYPES="video/mp4,video/quicktime,video/x-msvideo,video/webm"
STORAGE_PROVIDER="supabase"

# =================================
# Rate Limiting
# =================================
RATE_LIMIT_WINDOW="900000"
RATE_LIMIT_MAX="100"

# =================================
# Email Configuration (Optional)
# =================================
EMAIL_PROVIDER="sendgrid"
EMAIL_FROM="noreply@haraka.edu.sa"
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASSWORD="your-sendgrid-api-key"

# =================================
# SMS Configuration (Optional)
# =================================
SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="your-twilio-phone-number"

# =================================
# Push Notifications (Optional)
# =================================
PUSH_NOTIFICATION_KEY="your-push-notification-key"
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_CLIENT_EMAIL="your-firebase-client-email"

# =================================
# Analytics & Monitoring
# =================================
NEXT_PUBLIC_ANALYTICS_ID="your-google-analytics-id"
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
LOG_LEVEL="info"

# =================================
# AI & External APIs (Optional)
# =================================
AI_ANALYSIS_API="https://api.your-ai-service.com"
AI_API_KEY="your-ai-api-key"
OPENAI_API_KEY="your-openai-api-key"

# =================================
# Caching & Performance
# =================================
CACHE_TTL="300000"
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="your-redis-password"

# =================================
# CDN & Static Assets (Optional)
# =================================
CDN_URL="https://cdn.haraka.edu.sa"
NEXT_PUBLIC_CDN_URL="https://cdn.haraka.edu.sa"

# =================================
# SSL Configuration (Production Only)
# =================================
ENABLE_HTTPS="false"
SSL_CERT_PATH="/etc/ssl/certs/haraka.crt"
SSL_KEY_PATH="/etc/ssl/private/haraka.key"

# =================================
# Backup Configuration
# =================================
BACKUP_ENABLED="true"
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="30"
BACKUP_STORAGE_PATH="/opt/backups"

# =================================
# Health Check & Monitoring
# =================================
HEALTH_CHECK_INTERVAL="30000"
METRICS_ENABLED="true"
PROMETHEUS_PORT="9090"

# =================================
# Feature Flags
# =================================
ENABLE_REAL_TIME="true"
ENABLE_NOTIFICATIONS="true"
ENABLE_FILE_UPLOAD="true"
ENABLE_ANALYTICS="true"
ENABLE_AI_ANALYSIS="false"

# =================================
# Development Only
# =================================
DEBUG="false"
VERBOSE_LOGGING="false"
MOCK_AI_RESPONSES="false"
DISABLE_AUTH="false"

# =================================
# Testing Configuration
# =================================
TEST_DATABASE_URL="postgresql://postgres:test@localhost:5433/haraka_test"
TEST_SUPABASE_URL="http://localhost:54321"
TEST_SUPABASE_ANON_KEY="test-anon-key"

# =================================
# Docker Configuration
# =================================
DOCKER_REGISTRY="your-docker-registry.com"
DOCKER_IMAGE_TAG="latest"

# =================================
# Deployment Configuration
# =================================
DEPLOYMENT_ENVIRONMENT="development"
BUILD_ID="local"
COMMIT_SHA="local"
BRANCH_NAME="main"

# =================================
# Localization
# =================================
DEFAULT_LOCALE="ar"
SUPPORTED_LOCALES="ar,en"
TIMEZONE="Asia/Riyadh"

# =================================
# API Versioning
# =================================
API_VERSION="v1"
API_PREFIX="/api"

# =================================
# Session Configuration
# =================================
SESSION_SECRET="your-session-secret"
SESSION_MAX_AGE="86400000"
SESSION_SECURE="false"

# =================================
# CORS Configuration
# =================================
CORS_CREDENTIALS="true"
CORS_MAX_AGE="86400"

# =================================
# File Processing
# =================================
MAX_CONCURRENT_UPLOADS="5"
VIDEO_PROCESSING_TIMEOUT="300000"
IMAGE_RESIZE_QUALITY="80"

# =================================
# Database Optimization
# =================================
DB_CONNECTION_TIMEOUT="30000"
DB_QUERY_TIMEOUT="60000"
DB_IDLE_TIMEOUT="10000"

# =================================
# Security Headers
# =================================
ENABLE_SECURITY_HEADERS="true"
CSP_POLICY="default-src 'self'"
HSTS_MAX_AGE="31536000"

# =================================
# Performance Monitoring
# =================================
PERFORMANCE_BUDGET_JS="500000"
PERFORMANCE_BUDGET_CSS="100000"
PERFORMANCE_BUDGET_IMAGES="2000000"

# =================================
# Error Handling
# =================================
ERROR_STACK_TRACE="false"
ERROR_REPORTING="true"
MAX_ERROR_LOG_SIZE="10485760"

# =================================
# Notes:
# - Replace all placeholder values with actual values
# - Keep sensitive information secure and never commit to version control
# - Use different values for development, staging, and production environments
# - Regularly rotate secrets and API keys
# - Validate all environment variables on application startup
# =================================
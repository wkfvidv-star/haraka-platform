# Database Configuration
DATABASE_URL=postgresql://postgres:haraka_secure_2024@localhost:5432/haraka_db
POSTGRES_DB=haraka_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=haraka_secure_2024

# Supabase Configuration (Alternative)
SUPABASE_URL=http://localhost:3001
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_DB_URL=postgresql://supabase_admin:supabase_secure_2024@localhost:54322/postgres

# Authentication
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
JWT_EXPIRATION=3600

# Redis Configuration
REDIS_URL=redis://:redis_secure_2024@localhost:6379

# Security Configuration
AUDIT_LOG_RETENTION_DAYS=365
SECURITY_ALERT_EMAIL=security@haraka.edu.sa
ADMIN_EMAIL=admin@haraka.edu.sa

# Application Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api

# pgAdmin Configuration
PGADMIN_EMAIL=admin@haraka.edu.sa
PGADMIN_PASSWORD=admin_secure_2024

# Monitoring Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=monitor_secure_2024

# File Upload Configuration
MAX_FILE_SIZE=10MB
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@haraka.edu.sa

# Security Headers
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/haraka.log